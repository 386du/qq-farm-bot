# --- Farm Go Service 配置示例 ---
# 复制为 .env 后填写真实值,再用 docker compose up -d 启动

# 本服务监听端口(宿主机端口,容器内固定 8060)
PORT=8060

# Gewechat 后端地址(必填,不要带 / 结尾)
GEWE_BASE=http://127.0.0.1:2531

# Gewechat Token(必填)
# 启动时若留空,服务会自动 POST {GEWE_BASE}/tools/getTokenId 拿一个
# 正式环境建议手动从 Gewechat 管理后台固定一个 Token,避免每次重启变化
GEWE_TOKEN=

# 下游 JSLogin 服务地址(必填)
# 这是你现有 wxlogin 那套服务的地址,默认 http://127.0.0.1:8059/api
# 若没部署,JSLogin 端点不可用
JSLOGIN_API=http://127.0.0.1:8059/api

# 微信小程序 AppID
APPID=wx5306c5978fdb76e4

# Gewechat 区域 ID(默认 320000 江苏,海外可改为其他值)
REGION_ID=320000

# Gewechat 设备类型(ipad / mac)
DEVICE_TYPE=mac

# 日志前缀
LOG_PREFIX=[farm-go]
